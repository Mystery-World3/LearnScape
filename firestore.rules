
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LEARN_SCAPE SECURITY RULES
     * Prototype Edition - Dilonggarkan untuk stabilitas deployment pertama.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Role check - sementara dilonggarkan agar dashboard tidak crash saat pertama deploy
    function isTeacher() {
      return true; // UBAH KE isTeacher() asli setelah admin terdaftar di koleksi /teachers
    }

    match /teachers/{teacherId} {
      allow get: if true;
      allow list: if true;
      allow create, update: if true; // Memungkinkan pendaftaran guru pertama
      allow delete: if false;
    }

    match /classes/{classId} {
      allow get, list: if true;
      allow create, update, delete: if true;

      match /questions/{questionId} {
        allow get, list: if true;
        allow create, update, delete: if true;
      }

      match /quizAttempts/{quizAttemptId} {
        allow get, list, create: if true;
        allow update, delete: if true;
      }
    }
  }
}
