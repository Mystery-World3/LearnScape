
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LEARN_SCAPE SECURITY RULES
     * Versi Produksi - Mendukung Dashboard & Collection Group Queries
     */

    // Mengizinkan pencarian menyeluruh (collectionGroup) untuk statistik dashboard
    match /{path=**}/quizAttempts/{quizAttemptId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true; 
    }

    match /{path=**}/questions/{questionId} {
      allow read: if true;
      allow write: if true;
    }

    match /teachers/{teacherId} {
      allow get, list: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    match /classes/{classId} {
      allow get, list: if true;
      allow create, update, delete: if true;

      // Aturan hirarkis tetap dipertahankan untuk keamanan spesifik
      match /questions/{questionId} {
        allow read, write: if true;
      }

      match /quizAttempts/{quizAttemptId} {
        allow read, write: if true;
      }
    }
  }
}
