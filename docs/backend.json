{
  "entities": {
    "Class": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Class",
      "type": "object",
      "description": "Represents a course or subject that students can select and teachers can manage, containing associated quizzes and questions.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Class entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the class."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the class."
        },
        "isActive": {
          "type": "boolean",
          "description": "Indicates if the class is currently visible to students."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "isActive"
      ]
    },
    "Question": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Question",
      "type": "object",
      "description": "Represents a single math question of various types.",
      "properties": {
        "id": {
          "type": "string"
        },
        "classId": {
          "type": "string"
        },
        "statement": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["multiple-choice", "number", "text"]
        },
        "options": {
          "type": "array",
          "items": { "type": "string" }
        },
        "correctAnswerIndex": {
          "type": "number"
        },
        "correctAnswer": {
          "type": "string"
        },
        "solutionSteps": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": [
        "id",
        "classId",
        "statement",
        "type"
      ]
    },
    "QuizAttempt": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "QuizAttempt",
      "type": "object",
      "description": "Records a student's submission for a quiz.",
      "properties": {
        "id": {
          "type": "string"
        },
        "classId": {
          "type": "string"
        },
        "studentName": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "score": {
          "type": "number"
        },
        "answers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "questionId": { "type": "string" },
              "selectedOptionIndex": { "type": "number" },
              "studentAnswer": { "type": "string" },
              "isCorrect": { "type": "boolean" }
            }
          }
        }
      },
      "required": [
        "id",
        "classId",
        "studentName",
        "score"
      ]
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/classes/{classId}",
        "definition": {
          "entityName": "Class",
          "schema": {
            "$ref": "#/backend/entities/Class"
          },
          "description": "Stores class information and activation status."
        }
      },
      {
        "path": "/classes/{classId}/questions/{questionId}",
        "definition": {
          "entityName": "Question",
          "schema": {
            "$ref": "#/backend/entities/Question"
          },
          "description": "Contains questions for a specific class."
        }
      },
      {
        "path": "/classes/{classId}/quizAttempts/{quizAttemptId}",
        "definition": {
          "entityName": "QuizAttempt",
          "schema": {
            "$ref": "#/backend/entities/QuizAttempt"
          },
          "description": "Records student quiz results."
        }
      }
    ]
  }
}
